{"orig":"/Users/kalaverin/src/lang/nim/lib/std/setutils.nim","nimble":"stdlib","moduleDescription":"This module adds functionality for the built-in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">set</span></span></tt> type.\n<h1><a class=\"toc-backref\" id=\"see-also\" href=\"#see-also\">See also</a></h1><ul class=\"simple\"><li><a class=\"reference external\" href=\"packedsets.html\">std/packedsets</a></li>\n<li><a class=\"reference external\" href=\"sets.html\">std/sets</a></li>\n</ul>\n","entries":[{"name":"toSet","type":"skTemplate","line":24,"col":0,"code":"template toSet(iter: untyped): untyped","signature":{"return":"untyped","arguments":[{"name":"iter","type":"untyped"}]},"description":"Returns a built-in set from the elements of the iterable <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">iter</span></span></tt>."},{"name":"fullSet","type":"skProc","line":42,"col":0,"code":"func fullSet[T](U: typedesc[T]): set[T] {.inline.}","signature":{"return":"set[T]","arguments":[{"name":"U","type":"typedesc[T]"}],"pragmas":["inline"],"genericParams":[{"name":"T"},{"name":"U:type","types":"T"}]},"description":"Returns a set containing all elements in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">U</span></span></tt>."},{"name":"complement","type":"skProc","line":54,"col":0,"code":"func complement[T](s: set[T]): set[T] {.inline.}","signature":{"return":"set[T]","arguments":[{"name":"s","type":"set[T]"}],"pragmas":["inline"],"genericParams":[{"name":"T"}]},"description":"Returns the set complement of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">a</span></span></tt>."},{"name":"`[]=`","type":"skProc","line":65,"col":0,"code":"func `[]=`[T](t: var set[T]; key: T; val: bool) {.inline.}","signature":{"arguments":[{"name":"t","type":"var set[T]"},{"name":"key","type":"T"},{"name":"val","type":"bool"}],"pragmas":["inline"],"genericParams":[{"name":"T"}]