{"orig":"/Users/kalaverin/src/lang/nim/lib/std/assertions.nim","nimble":"stdlib","moduleDescription":"This module implements assertion handling.","entries":[{"name":"raiseAssert","type":"skProc","line":35,"col":0,"code":"proc raiseAssert(msg: string) {.noinline, noreturn, nosinks, raises: [],\n                                tags: [], forbids: [].}","signature":{"arguments":[{"name":"msg","type":"string"}],"pragmas":["noinline","noreturn","nosinks","raises: []","tags: []","forbids: []"]},"description":"Raises an <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">AssertionDefect</span></span></tt> with <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">msg</span></span></tt>."},{"name":"failedAssertImpl","type":"skProc","line":42,"col":0,"code":"proc failedAssertImpl(msg: string) {.raises: [], tags: [], forbids: [].}","signature":{"arguments":[{"name":"msg","type":"string"}],"pragmas":["raises: []","tags: []","forbids: []"]},"description":"Raises an <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">AssertionDefect</span></span></tt> with <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">msg</span></span></tt>, but this is hidden from the effect system. Called when an assertion failed."},{"name":"assert","type":"skTemplate","line":58,"col":0,"code":"template assert(cond: untyped; msg = \"\")","signature":{"arguments":[{"name":"cond","type":"untyped"},{"name":"msg","type":"","default":"\"\""}]},"description":"<p>Raises <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">AssertionDefect</span></span></tt> with <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">msg</span></span></tt> if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">cond</span></span></tt> is false. Note that <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">AssertionDefect</span></span