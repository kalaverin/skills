{"orig":"/Users/kalaverin/src/lang/nim/lib/std/isolation.nim","nimble":"stdlib","moduleDescription":"This module implements the <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">Isolated</span><span class=\"Punctuation\">[</span><span class=\"Identifier\">T</span><span class=\"Punctuation\">]</span></span></tt> type for safe construction of isolated subgraphs that can be passed efficiently to different channels and threads.<div class=\"admonition admonition-warning\"><span class=\"admonition-warning-text\"><b>Warning:</b></span>\nThis module is experimental and its interface may change.</div>\n","entries":[{"name":"Isolated","type":"skType","line":18,"col":28,"code":"Isolated[T] {.sendable.} = object","description":"Isolated data can only be moved, not copied."},{"name":"`=copy`","type":"skProc","line":21,"col":0,"code":"proc `=copy`[T](dest: var Isolated[T]; src: Isolated[T]) {.error.}","signature":{"arguments":[{"name":"dest","type":"var Isolated[T]"},{"name":"src","type":"Isolated[T]"}],"pragmas":["error"],"genericParams":[{"name":"T"}]}},{"name":"`=sink`","type":"skProc","line":23,"col":0,"code":"proc `=sink`[T](dest: var Isolated[T]; src: Isolated[T]) {.inline.}","signature":{"arguments":[{"name":"dest","type":"var Isolated[T]"},{"name":"src","type":"Isolated[T]"}],"pragmas":["inline"],"genericParams":[{"name":"T"}]}},{"name":"`=destroy`","type":"skProc","line":27,"col":0,"code":"proc `=destroy`[T](dest: var Isolated[T]) {.inline, raises: [].}","signature":{"arguments":[{"name":"dest","type":"var Isolated[T]"}],"pragmas":["inline","raises: []"],"genericParams":[{"name":"T"}]}},{"name":"isolate","type":"skProc","line":31,"col":0,"code":"func isolate[T](value: sink T): Isolated[T] {.magic: \"Isolate\", raises: [],\n    tags: [], forbids: [].}","signature":{"return":"Isolated[T]","arguments":[{"name":"value","type":"sink T"}],"pragmas":["magic: \"Isolate\"","raises: []","tags: []","forbids: []"],"genericParams":[{"name":"T"}]},"descript