{"orig":"/Users/kalaverin/src/lang/nim/lib/std/wrapnils.nim","nimble":"stdlib","moduleDescription":"This module allows evaluating expressions safely against the following conditions:<ul class=\"simple\"><li>nil dereferences</li>\n<li>field accesses with incorrect discriminant in case objects</li>\n</ul>\n<p><tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">default</span><span class=\"Punctuation\">(</span><span class=\"Identifier\">T</span><span class=\"Punctuation\">)</span></span></tt> is returned in those cases when evaluating an expression of type <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">T</span></span></tt>. This simplifies code by reducing need for if-else branches.</p>\n<p>Note: experimental module, unstable API.</p>\n","entries":[{"name":"`?.`","type":"skMacro","line":112,"col":0,"code":"macro `?.`(a: typed): auto","signature":{"return":"auto","arguments":[{"name":"a","type":"typed"}]},"description":"Transforms <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">a</span></span></tt> into an expression that can be safely evaluated even in presence of intermediate nil pointers/references, in which case a default value is produced."},{"name":"`??.`","type":"skMacro","line":128,"col":0,"code":"macro `??.`(a: typed): Option","signature":{"return":"Option","arguments":[{"name":"a","type":"typed"}],"genericParams":[{"name":"Option","types":"Option[any]"}]},"description":"Same as <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Operator\">?.</span></span></tt> but returns an <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">Option</span></span></tt>."},{"name":"fakeDot","type":"skTemplate","line":159,"col":0,"code":"template fakeDot(a: Option; b): untyped","signature":{"return":"untyped","arguments":[{"name":"a","type":"Option"},{"name":"b","type":""}],"genericParams":[{"name":"Option","types":"Option[any]"}]},"description":"See top-level example."},{"name":"`[]`","type":"skProc","line":178,"col":0,"code":"func `[]`[T, I](a: Option[T]; i: I): auto {.inline.}","signature":{"return":"auto","arguments":[{"name":"a","type":"Option[T]"},{"name":"i","type":"I"}],"pragmas":["inline"],"genericParams":[{"name":"T"},{"name":"I"}]},"description":"See top-level example."},{"name":"`[]`","type":"skProc","line":184,"col":0,"code":"func `[]`[U](a: Option[U]): auto {.inline.}","signature":{"return":"auto","arguments":[{"name":"a","type":"Option[U]"}],"pragmas":["inline"],"genericParams":[{"name":"U"}]},"description":"See top-level example."}]}