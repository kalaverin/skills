{"orig":"/Users/kalaverin/src/lang/nim/lib/std/packedsets.nim","nimble":"stdlib","moduleDescription":"<p>The <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">packedsets</span></span></tt> module implements an efficient <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">Ordinal</span></span></tt> set implemented as a <span id=\"sparse-bit-set_1\">sparse bit set</span>.</p>\n<p>Supports any Ordinal type.</p>\n\n<h1><a class=\"toc-backref\" id=\"see-also\" href=\"#see-also\">See also</a></h1><ul class=\"simple\"><li><a class=\"reference external\" href=\"sets.html\">sets module</a> for more general hash sets</li>\n</ul>\n","entries":[{"name":"PackedSet","type":"skType","line":46,"col":25,"code":"PackedSet[A] = object","description":"An efficient set of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">Ordinal</span></span></tt> types implemented as a sparse bit set."},{"name":"items","type":"skIterator","line":138,"col":0,"code":"iterator items[A](s: PackedSet[A]): A {.inline.}","signature":{"return":"A","arguments":[{"name":"s","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"Iterates over any included element of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>."},{"name":"initPackedSet","type":"skProc","line":160,"col":0,"code":"proc initPackedSet[A](): PackedSet[A]","signature":{"return":"PackedSet[A]","genericParams":[{"name":"A"}]},"description":"<p>Returns an empty <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">PackedSet</span><span class=\"Punctuation\">[</span><span class=\"Identifier\">A</span><span class=\"Punctuation\">]</span></span></tt>. <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">A</span></span></tt> must be <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">Ordinal</span></span></tt>.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#toPackedSet,openArray[A]\">toPackedSet proc</a></li>\n</ul>\n"},{"name":"contains","type":"skProc","line":182,"col":0,"code":"proc contains[A](s: PackedSet[A]; key: A): bool","signature":{"return":"bool","arguments":[{"name":"s","type":"PackedSet[A]"},{"name":"key","type":"A"}],"genericParams":[{"name":"A"}]},"description":"<p>Returns true if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> is in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>This allows the usage of the <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Keyword\">in</span></span></tt> operator.</p>\n"},{"name":"incl","type":"skProc","line":213,"col":0,"code":"proc incl[A](s: var PackedSet[A]; key: A)","signature":{"arguments":[{"name":"s","type":"var PackedSet[A]"},{"name":"key","type":"A"}],"genericParams":[{"name":"A"}]},"description":"<p>Includes an element <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>This doesn't do anything if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> is already in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#excl,PackedSet[A],A\">excl proc</a> for excluding an element</li>\n<li><a class=\"reference external\" href=\"#incl,PackedSet[A],PackedSet[A]\">incl proc</a> for including a set</li>\n<li><a class=\"reference external\" href=\"#containsOrIncl,PackedSet[A],A\">containsOrIncl proc</a></li>\n</ul>\n"},{"name":"incl","type":"skProc","line":243,"col":0,"code":"proc incl[A](s: var PackedSet[A]; other: PackedSet[A])","signature":{"arguments":[{"name":"s","type":"var PackedSet[A]"},{"name":"other","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Includes all elements from <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">other</span></span></tt> into <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>This is the in-place version of <a class=\"reference external\" href=\"#+,PackedSet[A],PackedSet[A]\">s + other</a>.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#excl,PackedSet[A],PackedSet[A]\">excl proc</a> for excluding a set</li>\n<li><a class=\"reference external\" href=\"#incl,PackedSet[A],A\">incl proc</a> for including an element</li>\n<li><a class=\"reference external\" href=\"#containsOrIncl,PackedSet[A],A\">containsOrIncl proc</a></li>\n</ul>\n"},{"name":"toPackedSet","type":"skProc","line":260,"col":0,"code":"proc toPackedSet[A](x: openArray[A]): PackedSet[A]","signature":{"return":"PackedSet[A]","arguments":[{"name":"x","type":"openArray[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Creates a new <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">PackedSet</span><span class=\"Punctuation\">[</span><span class=\"Identifier\">A</span><span class=\"Punctuation\">]</span></span></tt> that contains the elements of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">x</span></span></tt>.</p>\n<p>Duplicates are removed.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#initPackedSet\">initPackedSet proc</a></li>\n</ul>\n"},{"name":"containsOrIncl","type":"skProc","line":276,"col":0,"code":"proc containsOrIncl[A](s: var PackedSet[A]; key: A): bool","signature":{"return":"bool","arguments":[{"name":"s","type":"var PackedSet[A]"},{"name":"key","type":"A"}],"genericParams":[{"name":"A"}]},"description":"<p>Includes <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> in the set <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt> and tells if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> was already in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>The difference with regards to the <a class=\"reference external\" href=\"#incl,PackedSet[A],A\">incl proc</a> is that this proc returns true if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt> already contained <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt>. The proc will return false if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> was added as a new value to <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt> during this call.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#incl,PackedSet[A],A\">incl proc</a> for including an element</li>\n<li><a class=\"reference external\" href=\"#missingOrExcl,PackedSet[A],A\">missingOrExcl proc</a></li>\n</ul>\n"},{"name":"excl","type":"skProc","line":315,"col":0,"code":"proc excl[A](s: var PackedSet[A]; key: A)","signature":{"arguments":[{"name":"s","type":"var PackedSet[A]"},{"name":"key","type":"A"}],"genericParams":[{"name":"A"}]},"description":"<p>Excludes <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> from the set <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>This doesn't do anything if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> is not found in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#incl,PackedSet[A],A\">incl proc</a> for including an element</li>\n<li><a class=\"reference external\" href=\"#excl,PackedSet[A],PackedSet[A]\">excl proc</a> for excluding a set</li>\n<li><a class=\"reference external\" href=\"#missingOrExcl,PackedSet[A],A\">missingOrExcl proc</a></li>\n</ul>\n"},{"name":"excl","type":"skProc","line":333,"col":0,"code":"proc excl[A](s: var PackedSet[A]; other: PackedSet[A])","signature":{"arguments":[{"name":"s","type":"var PackedSet[A]"},{"name":"other","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Excludes all elements from <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">other</span></span></tt> from <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>This is the in-place version of <a class=\"reference external\" href=\"#-,PackedSet[A],PackedSet[A]\">s - other</a>.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#incl,PackedSet[A],PackedSet[A]\">incl proc</a> for including a set</li>\n<li><a class=\"reference external\" href=\"#excl,PackedSet[A],A\">excl proc</a> for excluding an element</li>\n<li><a class=\"reference external\" href=\"#missingOrExcl,PackedSet[A],A\">missingOrExcl proc</a></li>\n</ul>\n"},{"name":"len","type":"skProc","line":351,"col":0,"code":"proc len[A](s: PackedSet[A]): int {.inline.}","signature":{"return":"int","arguments":[{"name":"s","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"Returns the number of elements in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>."},{"name":"missingOrExcl","type":"skProc","line":365,"col":0,"code":"proc missingOrExcl[A](s: var PackedSet[A]; key: A): bool","signature":{"return":"bool","arguments":[{"name":"s","type":"var PackedSet[A]"},{"name":"key","type":"A"}],"genericParams":[{"name":"A"}]},"description":"<p>Excludes <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> from the set <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt> and tells if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> was already missing from <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>.</p>\n<p>The difference with regards to the <a class=\"reference external\" href=\"#excl,PackedSet[A],A\">excl proc</a> is that this proc returns true if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> was missing from <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt>. The proc will return false if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">key</span></span></tt> was in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt> and it was removed during this call.</p>\n<p><strong>See also:</strong></p>\n<ul class=\"simple\"><li><a class=\"reference external\" href=\"#excl,PackedSet[A],A\">excl proc</a> for excluding an element</li>\n<li><a class=\"reference external\" href=\"#excl,PackedSet[A],PackedSet[A]\">excl proc</a> for excluding a set</li>\n<li><a class=\"reference external\" href=\"#containsOrIncl,PackedSet[A],A\">containsOrIncl proc</a></li>\n</ul>\n"},{"name":"clear","type":"skProc","line":386,"col":0,"code":"proc clear[A](result: var PackedSet[A])","signature":{"arguments":[{"name":"result","type":"var PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"Clears the <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">PackedSet</span><span class=\"Punctuation\">[</span><span class=\"Identifier\">A</span><span class=\"Punctuation\">]</span></span></tt> back to an empty state."},{"name":"isNil","type":"skProc","line":402,"col":0,"code":"proc isNil[A](x: PackedSet[A]): bool {.inline.}","signature":{"return":"bool","arguments":[{"name":"x","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"Returns true if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">x</span></span></tt> is empty, false otherwise."},{"name":"`=copy`","type":"skProc","line":414,"col":0,"code":"proc `=copy`[A](dest: var PackedSet[A]; src: PackedSet[A])","signature":{"arguments":[{"name":"dest","type":"var PackedSet[A]"},{"name":"src","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"Copies <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">src</span></span></tt> to <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">dest</span></span></tt>. <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">dest</span></span></tt> does not need to be initialized by the <a class=\"reference external\" href=\"#initPackedSet\">initPackedSet proc</a>."},{"name":"assign","type":"skProc","line":445,"col":0,"code":"proc assign[A](dest: var PackedSet[A]; src: PackedSet[A]) {.inline, deprecated.}","signature":{"arguments":[{"name":"dest","type":"var PackedSet[A]"},{"name":"src","type":"PackedSet[A]"}],"pragmas":["inline","deprecated"],"genericParams":[{"name":"A"}]},"description":"Copies <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">src</span></span></tt> to <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">dest</span></span></tt>. <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">dest</span></span></tt> does not need to be initialized by the <a class=\"reference external\" href=\"#initPackedSet\">initPackedSet proc</a>."},{"name":"union","type":"skProc","line":458,"col":0,"code":"proc union[A](s1, s2: PackedSet[A]): PackedSet[A]","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Returns the union of the sets <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> and <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>.</p>\n<p>The same as <a class=\"reference external\" href=\"#+,PackedSet[A],PackedSet[A]\">s1 + s2</a>.</p>\n"},{"name":"intersection","type":"skProc","line":473,"col":0,"code":"proc intersection[A](s1, s2: PackedSet[A]): PackedSet[A]","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Returns the intersection of the sets <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> and <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>.</p>\n<p>The same as <a class=\"reference external\" href=\"#*,PackedSet[A],PackedSet[A]\">s1 * s2</a>.</p>\n"},{"name":"difference","type":"skProc","line":490,"col":0,"code":"proc difference[A](s1, s2: PackedSet[A]): PackedSet[A]","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Returns the difference of the sets <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> and <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>.</p>\n<p>The same as <a class=\"reference external\" href=\"#-,PackedSet[A],PackedSet[A]\">s1 - s2</a>.</p>\n"},{"name":"symmetricDifference","type":"skProc","line":507,"col":0,"code":"proc symmetricDifference[A](s1, s2: PackedSet[A]): PackedSet[A]","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"Returns the symmetric difference of the sets <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> and <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>."},{"name":"`+`","type":"skProc","line":522,"col":0,"code":"proc `+`[A](s1, s2: PackedSet[A]): PackedSet[A] {.inline.}","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"Alias for <a class=\"reference external\" href=\"#union,PackedSet[A],PackedSet[A]\">union(s1, s2)</a>."},{"name":"`*`","type":"skProc","line":526,"col":0,"code":"proc `*`[A](s1, s2: PackedSet[A]): PackedSet[A] {.inline.}","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"Alias for <a class=\"reference external\" href=\"#intersection,PackedSet[A],PackedSet[A]\">intersection(s1, s2)</a>."},{"name":"`-`","type":"skProc","line":530,"col":0,"code":"proc `-`[A](s1, s2: PackedSet[A]): PackedSet[A] {.inline.}","signature":{"return":"PackedSet[A]","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"Alias for <a class=\"reference external\" href=\"#difference,PackedSet[A],PackedSet[A]\">difference(s1, s2)</a>."},{"name":"disjoint","type":"skProc","line":534,"col":0,"code":"proc disjoint[A](s1, s2: PackedSet[A]): bool","signature":{"return":"bool","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"Returns true if the sets <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> and <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt> have no items in common."},{"name":"card","type":"skProc","line":549,"col":0,"code":"proc card[A](s: PackedSet[A]): int {.inline.}","signature":{"return":"int","arguments":[{"name":"s","type":"PackedSet[A]"}],"pragmas":["inline"],"genericParams":[{"name":"A"}]},"description":"<p>Alias for <a class=\"reference external\" href=\"#len,PackedSet[A]\">len()</a>.</p>\n<p>Card stands for the <a class=\"reference external\" href=\"https://en.wikipedia.org/wiki/Cardinality\">cardinality</a> of a set.</p>\n"},{"name":"`&lt;=`","type":"skProc","line":556,"col":0,"code":"proc `<=`[A](s1, s2: PackedSet[A]): bool","signature":{"return":"bool","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Returns true if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> is a subset of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>.</p>\n<p>A subset <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> has all of its elements in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>, but <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt> doesn't necessarily have more elements than <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt>. That is, <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> can be equal to <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>.</p>\n"},{"name":"`&lt;`","type":"skProc","line":575,"col":0,"code":"proc `<`[A](s1, s2: PackedSet[A]): bool","signature":{"return":"bool","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"<p>Returns true if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> is a proper subset of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>.</p>\n<p>A strict or proper subset <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> has all of its elements in <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt>, but <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt> has more elements than <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt>.</p>\n"},{"name":"`==`","type":"skProc","line":591,"col":0,"code":"proc `==`[A](s1, s2: PackedSet[A]): bool","signature":{"return":"bool","arguments":[{"name":"s1","type":"PackedSet[A]"},{"name":"s2","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"Returns true if both <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s1</span></span></tt> and <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s2</span></span></tt> have the same elements and set size."},{"name":"`$`","type":"skProc","line":599,"col":0,"code":"proc `$`[A](s: PackedSet[A]): string","signature":{"return":"string","arguments":[{"name":"s","type":"PackedSet[A]"}],"genericParams":[{"name":"A"}]},"description":"Converts <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">s</span></span></tt> to a string."}]}