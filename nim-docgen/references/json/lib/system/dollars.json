utils literal\"><span class=\"pre\"><span class=\"Identifier\">x</span></span></tt> as it is. This operator is useful for generic code, so that <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Operator\">$</span><span class=\"Identifier\">expr</span></span></tt> also works if <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">expr</span></span></tt> is already a string."},{"name":"`$`","type":"skProc","line":67,"col":0,"code":"proc `$`[Enum: enum](x: Enum): string {.magic: \"EnumToStr\", noSideEffect,\n                                        raises: [], tags: [], forbids: [].}","signature":{"return":"string","arguments":[{"name":"x","type":"Enum"}],"pragmas":["magic: \"EnumToStr\"","noSideEffect","raises: []","tags: []","forbids: []"],"genericParams":[{"name":"Enum","types":"enum"}]},"description":"<p>The stringify operator for an enumeration argument. This works for any enumeration type thanks to compiler magic.</p>\n<p>If a <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Operator\">$</span></span></tt> operator for a concrete enumeration is provided, this is used instead. (In other words: <em>Overwriting</em> is possible.)</p>\n"},{"name":"`$`","type":"skProc","line":74,"col":0,"code":"proc `$`(t: typedesc): string {.magic: \"TypeTrait\", raises: [], tags: [],\n                                forbids: [].}","signature":{"return":"string","arguments":[{"name":"t","type":"typedesc"}],"pragmas":["magic: \"TypeTrait\"","raises: []","tags: []","forbids: []"],"genericParams":[{"name":"t:type","types":"None"}]},"description":"<p>Returns the name of the given type.</p>\n<p>For more procedures dealing with <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">typedesc</span></span></tt>, see <a class=\"reference external\" href=\"typetraits.html\">typetraits module</a>.</p>\n<p><pre class=\"listing\"><span class=\"Identifier\">doAssert</span> <span class=\"Operator\">$</span><span class=\"Punctuation\">(</span><span class=\"Identifier\">typeof</span><span class=\"Punctuation\">(</span><span class=\"DecNumber\">42</span><span class=\"Punctuation\">)</span><span class=\"Punctuation\">)</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;int&quot;</span>\n<span class=\"Identifier\">doAssert</span> <span class=\"Operator\">$</span><span class=\"Punctuation\">(</span><span class=\"Identifier\">typeof</span><span class=\"Punctuation\">(</span><span class=\"StringLit\">&quot;Foo&quot;</span><span class=\"Punctuation\">)</span><span class=\"Punctuation\">)</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;string&quot;</span>\n<span class=\"Keyword\">static</span><span class=\"Punctuation\">:</span> <span class=\"Identifier\">doAssert</span> <span class=\"Operator\">$</span><span class=\"Punctuation\">(</span><span class=\"Identifier\">typeof</span><span class=\"Punctuation\">(</span><span class=\"Operator\">@</span><span class=\"Punctuation\">[</span><span class=\"CharLit\">'A'</span><span class=\"Punctuation\">,</span> <span class=\"CharLit\">'B'</span><span class=\"Punctuation\">]</span><span class=\"Punctuation\">)</span><span class=\"Punctuation\">)</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;seq[char]&quot;</span></pre></p>\n"},{"name":"`$`","type":"skProc","line":86,"col":0,"code":"proc `$`[T: tuple](x: T): string","signature":{"return":"string","arguments":[{"name":"x","type":"T"}],"genericParams":[{"name":"T","types":"tuple"}]},"description":"<p>Generic <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Operator\">$</span></span></tt> operator for tuples that is lifted from the components of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">x</span></span></tt>. Example:</p>\n<p><pre class=\"listing\"><span class=\"Operator\">$</span><span class=\"Punctuation\">(</span><span class=\"DecNumber\">23</span><span class=\"Punctuation\">,</span> <span class=\"DecNumber\">45</span><span class=\"Punctuation\">)</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;(23, 45)&quot;</span>\n<span class=\"Operator\">$</span><span class=\"Punctuation\">(</span><span class=\"Identifier\">a</span><span class=\"Punctuation\">:</span> <span class=\"DecNumber\">23</span><span class=\"Punctuation\">,</span> <span class=\"Identifier\">b</span><span class=\"Punctuation\">:</span> <span class=\"DecNumber\">45</span><span class=\"Punctuation\">)</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;(a: 23, b: 45)&quot;</span>\n<span class=\"Operator\">$</span><span class=\"Punctuation\">(</span><span class=\"Punctuation\">)</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;()&quot;</span></pre></p>\n"},{"name":"`$`","type":"skProc","line":119,"col":0,"code":"proc `$`[T](x: set[T]): string","signature":{"return":"string","arguments":[{"name":"x","type":"set[T]"}],"genericParams":[{"name":"T"}]},"description":"<p>Generic <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Operator\">$</span></span></tt> operator for sets that is lifted from the components of <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Identifier\">x</span></span></tt>. Example:</p>\n<p><pre class=\"listing\"><span class=\"Operator\">$</span><span class=\"Punctuation\">{</span><span class=\"DecNumber\">23</span><span class=\"Punctuation\">,</span> <span class=\"DecNumber\">45</span><span class=\"Punctuation\">}</span> <span class=\"Operator\">==</span> <span class=\"StringLit\">&quot;{23, 45}&quot;</span></pre></p>\n"},{"name":"`$`","type":"skProc","line":127,"col":0,"code":"proc `$`[T](x: seq[T]): string","signature":{"return":"string","arguments":[{"name":"x","type":"seq[T]"}],"genericParams":[{"name":"T"}]},"description":"<p>Generic <tt class=\"docutils literal\"><span class=\"pre\"><span class=\"Operator\">$</span></span></tt> operator for seqs that is lif